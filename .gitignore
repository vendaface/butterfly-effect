# Sensitive / session data
browser_state.json
config.yaml
monarch_accounts_cache.json

# User-specific runtime files
user_context.md
insights.json

# Dev/testing scripts
reset-for-testing.sh

# Python
__pycache__/
*.pyc
*.pyo

# Environment
.env

# macOS
.DS_Store

# iCloud conflict copies (e.g. "config 2.yaml", "browser_state 3.json", ".env 2")
* 2
* 3
* 4
* 2.*
* 3.*
* 4.*

# Server PID and log files
.server*.pid
.server*.log

# User data files (reset by reset script — not source controlled)
payment_overrides.json
payment_monthly_amounts.json
payment_skips.json
scenarios.json
dismissed_suggestions.json

# Local virtual environments (server.sh uses ~/.cache/balance-forecast-venv,
# but developers may create one in the project directory)
.venv*/

# Demo mode — all demo/ files are intentional, public demo data.
# Exceptions must come AFTER the patterns they override.
!demo/config.yaml
!demo/monarch_accounts_cache.json
!demo/insights.json
!demo/scenarios.json
!demo/user_context.md
!demo/payment_skips.json
!demo/payment_overrides.json
# demo/backup/ is created at runtime — do NOT track it
demo/backup/
